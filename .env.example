# 后台管理密码
ADMIN_PASSWORD=123456

# Upstash Redis/KV REST 配置
KV_REST_API_URL=https://your-redis-instance.upstash.io
KV_REST_API_TOKEN=your-upstash-redis-rest-token
UPSTASH_REDIS_KEY_PREFIX=navsphere

# Vercel Blob 配置（可选，用于 favicon / 资源图片持久缓存）
# Vercel 项目环境通常由 Blob Store 自动注入 BLOB_STORE_ID，并通过平台 OIDC 写入。
# 本地开发或非 Vercel 部署需要配置 BLOB_READ_WRITE_TOKEN。
# BLOB_STORE_ID=store_xxx
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
# BLOB_WEBHOOK_PUBLIC_KEY=xxx

# Favicon 缓存后台任务配置（可选）
# NAVSPHERE_FAVICON_BATCH_SIZE=40
# NAVSPHERE_FAVICON_BATCH_CONCURRENCY=6

# NextAuth 配置
# 部署平台能正确透传 Host 时通常不需要配置 AUTH_URL/NEXTAUTH_URL。
# 如需固定公开访问地址，可设置 AUTH_URL=https://your-domain.com，生产环境不能使用 localhost。
# AUTH_URL=http://localhost:3000
# Production requires a random AUTH_SECRET with at least 32 characters.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=generate-a-32-byte-random-secret-before-deploy
NEXT_PUBLIC_API_URL=http://localhost:3000
# 可选：Server Actions 允许的额外域名，多个用英文逗号分隔，例如 example.com,www.example.com
# SERVER_ACTION_ALLOWED_ORIGINS=

# Google Analytics 配置 (可选)
GA_ID=G-QG9PGG4K13
